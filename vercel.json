{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/main.tsx",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/(.*)", "dest": "/src/main.tsx" }
  ],
  "env": {
    "MONGO_URI": "your-mongodb-uri",
    "DB_NAME": "trading_journal",
    "JWT_SECRET": "your-jwt-secret",
    "SESSION_SECRET": "your-session-secret"
  }
}
